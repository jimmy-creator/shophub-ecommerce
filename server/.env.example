PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecom_db
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# SEO meta injection (htmlInject.js)
# Arabic site-level meta (only needed when FEATURE_I18N=true). Defaults are baked
# in for Anfal Sports; override per store. Per-product Arabic uses nameAr/descriptionAr.
# STORE_NAME_AR=
# SITE_TITLE_AR=
# DEFAULT_DESC_AR=
# LocalBusiness / SportingGoodsStore schema on the homepage. Omitted from the
# schema when blank so we never publish placeholder contact data.
# STORE_TELEPHONE=+965...
# STORE_SAMEAS=https://instagram.com/...,https://facebook.com/...

# WhatsApp notifications via Kapso (https://docs.kapso.ai)
# Entire feature no-ops silently unless KAPSO_API_KEY + KAPSO_PHONE_NUMBER_ID are
# both set, so it's safe to deploy before any of this is configured.
# KAPSO_API_KEY=
# KAPSO_PHONE_NUMBER_ID=
# KAPSO_API_URL=https://api.kapso.ai/meta/whatsapp/v24.0
# Webhook signing secret. In production an unset secret makes the webhook reject
# all events (fail-closed); only leave blank in dev.
# KAPSO_WEBHOOK_SECRET=
# National-number country code prepended to bare 10-digit phones (965 = Kuwait).
# WHATSAPP_COUNTRY_CODE=965
# Template language code (must match what you submit to Meta).
# WHATSAPP_TEMPLATE_LANG=en_US
# Approved template NAMES (see docs/whatsapp-templates.md). Blank → that send no-ops.
# WHATSAPP_TEMPLATE_ORDER_CONFIRMATION=order_confirmation
# WHATSAPP_TEMPLATE_ABANDONED_CART=abandoned_cart
# Optional auto-reply text for inbound messages (rate-limited 1/10min per number).
# Set to false/off to disable. Only fires inside the 24h customer-service window.
# WHATSAPP_AUTOREPLY=
# Verbose logging (full message bodies). Default off → metadata only, phone masked.
# WHATSAPP_DEBUG=false
